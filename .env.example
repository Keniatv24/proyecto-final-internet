# ⚙️ VARIABLES DE ENTORNO - EAFIT Registro
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env (sin el .example)
# 2. Reemplazar los valores con tus configuraciones reales
# 3. NUNCA subir .env a Git (incluir en .gitignore)
#
# cp .env.example .env

# ============================================
# BASE DE DATOS PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=proyecto_final
DB_USER=admin
DB_PASSWORD=admin123

# ============================================
# CONFIGURACIÓN FLASK
# ============================================
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion-123456

# ============================================
# IDIOMA (es para Español, en para Inglés)
# ============================================
LANGUAGE=es

# ============================================
# CORREO ELECTRÓNICO (Para FASE 3)
# ============================================
# Gmail SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-contraseña-aplicacion

# O usar otro servicio (SendGrid, Mailgun, etc.)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.xxxxx

# ============================================
# REMITENTE DE CORREOS
# ============================================
MAIL_FROM_ADDRESS=noreply@eafit.edu.co
MAIL_FROM_NAME=EAFIT Registro

# ============================================
# DESTINATARIOS PARA REPORTES (FASE 3)
# ============================================
REPORT_RECIPIENTS=admin@eafit.edu.co,estadisticas@eafit.edu.co

# ============================================
# AWS (Para deploy en FASE 6)
# ============================================
AWS_ACCESS_KEY_ID=tu-access-key
AWS_SECRET_ACCESS_KEY=tu-secret-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=eafit-proyecto

# ============================================
# DOMINIO Y SSL (Para FASE 6)
# ============================================
DOMAIN=eafit-registro.com
SSL_CERT_PATH=/etc/letsencrypt/live/eafit-registro.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/eafit-registro.com/privkey.pem

# ============================================
# CONFIGURACIONES AVANZADAS
# ============================================
# Timeout para conexiones BD
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Rate limiting (FASE 2+)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
