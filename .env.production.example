# ⚙️ VARIABLES DE PRODUCCIÓN - EAFIT Proyecto Final
#
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.production
# 2. Reemplazar values con configuración real
# 3. NUNCA subir .env.production a Git
# 4. Usar: export $(cat .env.production | xargs)

# ============================================
# INFORMACIÓN DEL SERVIDOR REMOTO
# ============================================
REMOTE_HOST=your-server.com
REMOTE_USER=eafit
REMOTE_PORT=22
REMOTE_PATH=/home/eafit/proyecto-final-internet

# ============================================
# SSH CONFIGURATION
# ============================================
SSH_KEY=~/.ssh/eafit-key

# ============================================
# BASE DE DATOS - PRODUCCIÓN
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=proyecto_final
DB_USER=admin
DB_PASSWORD=CAMBIAR_A_CONTRASEÑA_FUERTE_RANDOM

# ============================================
# FLASK CONFIGURATION - PRODUCCIÓN
# ============================================
FLASK_ENV=production
FLASK_DEBUG=0

# Secret key para sesiones (IMPORTANTE: generar con os.urandom(32))
# Generar: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_A_VALOR_RANDOM_FUERTE

# ============================================
# IDIOMA PRINCIPAL
# ============================================
LANGUAGE=es

# ============================================
# DOMINIO Y SSL
# ============================================
DOMAIN=your-server.com
USE_SSL=true
SSL_CERT_PATH=/etc/letsencrypt/live/your-server.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-server.com/privkey.pem

# ============================================
# CORREO ELECTRÓNICO - PRODUCCIÓN
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Para Gmail: Habilitar "Less secure app access" o usar App Password
# https://support.google.com/accounts/answer/185833

# O usar SendGrid (recomendado para producción)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxx

# ============================================
# REMITENTE Y DESTINATARIOS
# ============================================
MAIL_FROM_ADDRESS=noreply@your-server.com
MAIL_FROM_NAME=EAFIT Registro Sistema

# Emails separados por coma
REPORT_RECIPIENTS=admin@your-company.com,estadisticas@your-company.com

# ============================================
# LOGGING - PRODUCCIÓN
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/home/eafit/proyecto-final-internet/logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# ============================================
# PERFORMANCE - PRODUCCIÓN
# ============================================
# Workers de Gunicorn (recomendado: 2-4 * num_cores)
WORKERS=8

# Timeout (segundos)
WORKER_TIMEOUT=30

# Max requests antes de reiniciar worker
MAX_REQUESTS=1000

# ============================================
# SEGURIDAD - PRODUCCIÓN
# ============================================
# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # 1 hora

# CORS (si la interfaz está en diferente dominio)
CORS_ENABLED=false
CORS_ORIGINS=https://your-domain.com

# ============================================
# AWS (Si usas AWS Educate)
# ============================================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_BUCKET_NAME=eafit-proyecto

# ============================================
# DATABASE POOL - PRODUCCIÓN
# ============================================
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# BACKUP AUTOMÁTICO
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily  # daily, weekly, monthly
BACKUP_RETENTION=30    # días

# ============================================
# MONITOREO
# ============================================
MONITORING_ENABLED=true

# Datadog (opcional)
# DATADOG_API_KEY=...
# DATADOG_ENVIRONMENT=production

# Sentry para error tracking (opcional)
# SENTRY_DSN=https://...@sentry.io/...

# ============================================
# FEATURE FLAGS (Para FASE 2+)
# ============================================
FEATURE_ADMIN_DASHBOARD=true
FEATURE_EMAIL_REPORTS=false  # Activar cuando FASE 3 esté lista
FEATURE_MULTI_SERVER=false   # Activar cuando FASE 4 esté lista
FEATURE_NGINX_LB=false       # Activar cuando FASE 5 esté lista
FEATURE_SSL=false            # Activar cuando FASE 6 esté lista

# ============================================
# MANTENIMIENTO
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Sistema en mantenimiento. Regresa en 1 hora.

# ============================================
# NOTIFICACIONES
# ============================================
SLACK_WEBHOOK=https://hooks.slack.com/services/...  # Para alertas
TELEGRAM_BOT_TOKEN=...  # Para alertas en Telegram
